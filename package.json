{
  "name": "converge-global-be",
  "version": "1.0.0",
  "description": "Converge Global Backend",
  "main": "dist/app.js",
  "type": "module",
  "scripts": {
    "start": "node dist/app.js",
    "dev": "tsx src/app.ts",
    "build": "tsc",
    "lint": "eslint .",
    "type-check": "tsc --noEmit",
    "prep": "npm run lint && npm run type-check",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:studio": "drizzle-kit studio",
    "db:migrate": "drizzle-kit migrate",
    "test": "vitest",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest --coverage",
    "test:ui": "vitest --ui",
    "test:unit": "vitest run --reporter=verbose test/**/*.test.ts",
    "test:integration": "vitest run --reporter=verbose test/**/*.integration.test.ts",
    "test:e2e": "vitest run test/chat.e2e.test.ts",
    "test:e2e:debug": "DEBUG=* vitest run test/chat.e2e.test.ts --reporter=verbose",
    "test:load": "vitest run --reporter=verbose test/**/*.load.test.ts",
    "test:chat": "vitest run --reporter=verbose test/chat*.test.ts",
    "test:simple": "vitest run test/simple-test.ts",
    "test:handler": "vitest run test/chat.handler.test.ts",
    "dev:test": "npm run dev > server.log 2>&1 &",
    "kill:port": "./scripts/kill-port.sh",
    "seed:items": "tsx scripts/seed-items-from-csv.ts"
  },
  "keywords": [
    "express",
    "typescript",
    "nodejs"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@google-cloud/aiplatform": "^4.1.0",
    "@google-cloud/cloud-sql-connector": "^1.6.0",
    "@google-cloud/discoveryengine": "^2.0.1",
    "@google-cloud/documentai": "^9.1.0",
    "@google-cloud/firestore": "^7.11.0",
    "@google-cloud/functions-framework": "^3.5.1",
    "@google-cloud/language": "^7.0.1",
    "@google-cloud/pubsub": "^4.11.0",
    "@google-cloud/run": "^1.1.1",
    "@google-cloud/secret-manager": "^6.0.1",
    "@google-cloud/storage": "^7.16.0",
    "@google-cloud/vertexai": "^1.9.3",
    "@langchain/community": "^0.3.49",
    "@langchain/core": "^0.3.63",
    "@langchain/google-cloud-sql-pg": "^0.0.1",
    "@langchain/google-genai": "^0.2.15",
    "@langchain/google-vertexai": "^0.2.4",
    "@types/bcrypt": "^5.0.2",
    "@types/cookies": "^0.9.0",
    "@types/express-rate-limit": "^5.1.3",
    "@types/multer": "^1.4.12",
    "@types/pdfjs-dist": "^2.10.377",
    "axios": "^1.8.4",
    "bcrypt": "^6.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.2",
    "cookies": "^0.9.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.1",
    "drizzle-orm": "^0.44.3",
    "express": "^4.21.2",
    "express-rate-limit": "^8.4.0",
    "form-data": "^4.0.5",
    "google-auth-library": "^9.15.1",
    "google-gax": "^5.0.0-rc.3",
    "googleapis": "^131.0.0",
    "helmet": "^8.1.0",
    "inversify": "^7.5.1",
    "jsonwebtoken": "^9.0.2",
    "langchain": "^0.3.30",
    "mailgun.js": "^12.4.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.5",
    "pdfjs-dist": "^5.2.133",
    "pg": "^8.16.3",
    "redis": "^4.6.13",
    "reflect-metadata": "^0.2.2",
    "resend": "^6.6.0",
    "socket.io": "^4.8.1",
    "socket.io-client": "^4.8.1",
    "stream-json": "^1.9.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "uuid": "^11.1.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@eslint/js": "^9.20.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.23",
    "@types/node": "^20.11.16",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^8.0.0",
    "@types/pdf-parse": "^1.1.5",
    "@types/pg": "^8.15.4",
    "@types/redis": "^4.0.10",
    "@types/supertest": "^6.0.3",
    "@types/swagger-ui-express": "^4.1.8",
    "@types/ws": "^8.18.1",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "concurrently": "^9.1.2",
    "drizzle-kit": "^0.31.4",
    "eslint": "^8.57.1",
    "globals": "^15.15.0",
    "jest": "^29.7.0",
    "nodemon": "^3.0.3",
    "simple-git-hooks": "^2.11.1",
    "supertest": "^7.1.4",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.24.0",
    "vitest": "^3.2.4",
    "vitest-mock-extended": "^3.1.0"
  }
}
