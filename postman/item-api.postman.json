    {
      "name": "Get Item Hierarchy",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/items/hierarchy",
          "host": ["{{base_url}}"],
          "path": ["items", "hierarchy"]
        },
        "description": "Get complete hierarchy: solutions → categories → product counts"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has hierarchical structure\", function () {",
