              "    pm.expect(responseJson).to.be.an('array');",
              "    if (responseJson.length > 0) {",
              "        pm.expect(responseJson[0]).to.have.property('categories');",
              "        pm.expect(responseJson[0].categories).to.be.an('array');",
              "    }",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Single Item by ID",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/items/{{item_id}}",
          "host": ["{{base_url}}"],
          "path": ["items", "{{item_id}}"]
        },
        "description": "Get detailed information about a specific item (solution, category, or product)"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Item has all required fields\", function () {",
              "    const item = pm.response.json();",
              "    pm.expect(item).to.have.property('id');",
              "    pm.expect(item).to.have.property('name');",
              "    pm.expect(item).to.have.property('itemType');",
              "    pm.expect(item).to.have.property('isActive');",
              "    pm.expect(item).to.have.property('createdAt');",
              "});",
              "",
              "pm.test(\"Item type is valid\", function () {",
              "    const item = pm.response.json();",
              "    pm.expect(['solution', 'category', 'product']).to.include(item.itemType);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Search Items",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/items?search=internet&limit=5",
          "host": ["{{base_url}}"],
          "path": ["items"],
          "query": [
            {
              "key": "search",
              "value": "internet"
            },
            {
              "key": "limit",
              "value": "5"
            }
          ]
        },
        "description": "Search items by name or description across all types"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response has pagination info\", function () {",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.have.property('items');",
              "    pm.expect(responseJson).to.have.property('total');",
              "    pm.expect(responseJson).to.have.property('limit');",
              "    pm.expect(responseJson).to.have.property('offset');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Filter Items by Type",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/items?item_type=product&limit=10",
          "host": ["{{base_url}}"],
          "path": ["items"],
          "query": [
