{
  "info": {
    "_postman_id": "item-api-collection",
    "name": "Converge Item API (NEW)",
    "description": "Complete API tests for the unified Item model - solutions, categories, and products",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Get All Solutions",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/items/solutions",
          "host": ["{{base_url}}"],
          "path": ["items", "solutions"]
        },
        "description": "Get all top-level solutions (e.g., Connectivity Solutions, Managed Services)"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is array of solutions\", function () {",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.be.an('array');",
              "    pm.expect(responseJson.length).to.be.above(0);",
              "});",
              "",
              "pm.test(\"Each solution has required fields\", function () {",
              "    const responseJson = pm.response.json();",
              "    responseJson.forEach(solution => {",
              "        pm.expect(solution).to.have.property('id');",
              "        pm.expect(solution).to.have.property('name');",
              "        pm.expect(solution).to.have.property('itemType');",
              "        pm.expect(solution.itemType).to.eql('solution');",
              "        pm.expect(solution).to.have.property('isActive');",
              "        pm.expect(solution.isActive).to.be.true;",
              "    });",
              "});",
              "",
              "// Store first solution ID for subsequent tests",
              "if (pm.response.code === 200) {",
              "    const solutions = pm.response.json();",
              "    if (solutions.length > 0) {",
              "        pm.environment.set('solution_id', solutions[0].id);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get All Categories",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/items/categories",
          "host": ["{{base_url}}"],
          "path": ["items", "categories"]
        },
        "description": "Get all categories across all solutions"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response is array of categories\", function () {",
              "    const responseJson = pm.response.json();",
              "    pm.expect(responseJson).to.be.an('array');",
              "});",
              "",
              "pm.test(\"Each category has parentItemId\", function () {",
              "    const responseJson = pm.response.json();",
              "    responseJson.forEach(category => {",
              "        pm.expect(category).to.have.property('itemType');",
              "        pm.expect(category.itemType).to.eql('category');",
              "        pm.expect(category).to.have.property('parentItemId');",
              "    });",
              "});",
              "",
              "// Store first category ID",
              "if (pm.response.code === 200) {",
              "    const categories = pm.response.json();",
              "    if (categories.length > 0) {",
              "        pm.environment.set('category_id', categories[0].id);",
              "    }",
              "}"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "Get Categories by Solution",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{base_url}}/items/categories?solution_id={{solution_id}}",
          "host": ["{{base_url}}"],
          "path": ["items", "categories"],
          "query": [
            {
              "key": "solution_id",
              "value": "{{solution_id}}"
            }
          ]
        },
        "description": "Get categories filtered by specific solution"
      },
      "response": [],
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"All categories belong to solution\", function () {",
              "    const responseJson = pm.response.json();",
              "    const solutionId = parseInt(pm.environment.get('solution_id'));",
              "    responseJson.forEach(category => {",
              "        pm.expect(category.parentItemId).to.eql(solutionId);",
              "    });",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
