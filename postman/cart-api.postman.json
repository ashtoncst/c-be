        {
          "name": "Get Cart Contents",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/cart/{{session_id}}",
              "host": ["{{base_url}}"],
              "path": ["cart", "{{session_id}}"]
            },
            "description": "Retrieve all items in the cart for a specific session. This should show both items added with itemId and products added with productId."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Response has cart data\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('success');",
                  "    pm.expect(responseJson).to.have.property('data');",
                  "    pm.expect(responseJson.data).to.have.property('sessionId');",
                  "    pm.expect(responseJson.data).to.have.property('items');",
                  "    pm.expect(responseJson.data.items).to.be.an('array');",
                  "});",
                  "",
                  "pm.test(\"Each cart item has required fields\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.data.items.length > 0) {",
                  "        responseJson.data.items.forEach(item => {",
                  "            pm.expect(item).to.have.property('id');",
                  "            pm.expect(item).to.have.property('addedAt');",
                  "            // Should have either itemId or productId (or both for backward compat)",
                  "            const hasItemId = item.hasOwnProperty('itemId') && item.itemId !== null;",
                  "            const hasProductId = item.hasOwnProperty('productId') && item.productId !== null;",
                  "            pm.expect(hasItemId || hasProductId).to.be.true;",
                  "        });",
                  "    }",
                  "});",
                  "",
                  "pm.test(\"Cart items show correct name field\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    if (responseJson.data.items.length > 0) {",
                  "        responseJson.data.items.forEach(item => {",
                  "            // Should have either itemName or productName",
                  "            pm.expect(item.itemName || item.productName).to.exist;",
                  "        });",
                  "    }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Get Cart Item Count",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/cart/{{session_id}}/count",
