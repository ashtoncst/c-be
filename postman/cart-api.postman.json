              "raw": "{{base_url}}/cart/add",
              "host": ["{{base_url}}"],
              "path": ["cart", "add"]
            },
            "description": "Add a product to cart using LEGACY productId (backward compatibility). Example uses productId 1. Note: In the new model, use itemId instead for better support."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response indicates success\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('success');",
                  "    pm.expect(responseJson.success).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Response contains cart item data\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('data');",
                  "    pm.expect(responseJson.data).to.have.property('productId');",
                  "    pm.expect(responseJson.data).to.have.property('quantity');",
                  "});",
                  "",
                  "// Store product ID for removal test",
                  "if (pm.response.code === 201) {",
                  "    const responseJson = pm.response.json();",
                  "    pm.environment.set('added_product_id', responseJson.data.productId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
