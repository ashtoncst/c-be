    },
    {
      "name": "Cart Operations",
      "item": [
        {
          "name": "Add Item to Cart (NEW - itemId)",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"sessionId\": \"{{session_id}}\",\n  \"itemId\": 33\n}"
            },
            "url": {
              "raw": "{{base_url}}/cart/add",
              "host": ["{{base_url}}"],
              "path": ["cart", "add"]
            },
            "description": "Add an item to cart using NEW unified item model. Example: itemId 33 = 'Fiber Broadband PEAK 50-100 mbps' (SME product). You can use any item ID from 1-67."
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 201\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test(\"Response indicates success\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson).to.have.property('success');",
                  "    pm.expect(responseJson.success).to.be.true;",
                  "});",
                  "",
                  "pm.test(\"Response contains itemId\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.data).to.have.property('itemId');",
                  "    pm.expect(responseJson.data.itemId).to.eql(33);",
                  "});",
                  "",
                  "pm.test(\"Response contains item details\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.data).to.have.property('itemName');",
                  "    pm.expect(responseJson.data).to.have.property('itemType');",
                  "});",
                  "",
                  "// Store item ID for removal test",
                  "if (pm.response.code === 201) {",
                  "    const responseJson = pm.response.json();",
                  "    pm.environment.set('added_item_id', responseJson.data.itemId);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
