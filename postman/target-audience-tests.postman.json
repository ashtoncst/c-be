                  "pm.test(\"Audiences include expected types\", function () {",
                  "    const audiences = pm.response.json();",
                  "    const names = audiences.map(a => a.name);",
                  "    pm.expect(names).to.include('Hospitality');",
                  "    pm.expect(names).to.include('Banking & Financial Services');",
                  "    pm.expect(names).to.include('Enterprise');",
