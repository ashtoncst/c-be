{
  "info": {
    "_postman_id": "target-audience-collection",
    "name": "Converge Target Audience Tests",
    "description": "Comprehensive tests for target audience filtering and industry-specific recommendations with 67 seeded items",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Verify Database Seeding",
      "item": [
        {
          "name": "Verify All 67 Items Seeded",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/items?limit=100",
              "host": ["{{base_url}}"],
              "path": ["items"],
              "query": [
                {
                  "key": "limit",
                  "value": "100"
                }
              ]
            },
            "description": "Verify that all 67 items (7 solutions, 25 categories, 35 products) were seeded correctly"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Total items is 67\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    pm.expect(responseJson.total).to.eql(67);",
                  "});",
                  "",
                  "pm.test(\"All items are active\", function () {",
                  "    const responseJson = pm.response.json();",
                  "    responseJson.items.forEach(item => {",
                  "        pm.expect(item.isActive).to.be.true;",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Verify 7 Solutions",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/items/solutions",
              "host": ["{{base_url}}"],
              "path": ["items", "solutions"]
            },
            "description": "Verify all 7 top-level solutions were seeded"
          },
          "response": [],
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"Status code is 200\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test(\"Exactly 7 solutions\", function () {",
                  "    const solutions = pm.response.json();",
                  "    pm.expect(solutions.length).to.eql(7);",
                  "});",
                  "",
                  "pm.test(\"Solutions include expected items\", function () {",
                  "    const solutions = pm.response.json();",
                  "    const names = solutions.map(s => s.name);",
                  "    pm.expect(names).to.include('Internet');",
                  "    pm.expect(names).to.include('Transport');",
                  "    pm.expect(names).to.include('Satellite');",
                  "    pm.expect(names).to.include('Content');",
                  "    pm.expect(names).to.include('Security Anti-DDos');",
                  "});",
                  "",
                  "// Store Internet solution ID (ID: 1)",
                  "const internetSolution = pm.response.json().find(s => s.name === 'Internet');",
                  "if (internetSolution) {",
                  "    pm.environment.set('internet_solution_id', internetSolution.id);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ]
        },
        {
          "name": "Verify 25 Categories",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{base_url}}/items/categories",
