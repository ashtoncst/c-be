### 3. Repositories examples

```typescript
// src/repositories/document.repository.ts
import { Document, ProcessingStatus } from "../models/document.model";
import { getPool } from "../config/database";

export class DocumentRepository {
  async findById(id: string): Promise<Document | null> {
    const query = `
      SELECT * FROM documents 
      WHERE id = $1
    `;
    
    const result = await getPool().query(query, [id]);
    
    if (result.rows.length === 0) {
      return null;
    }
    
    return result.rows[0] as Document;
  }
  
  async updateStatus(id: string, status: ProcessingStatus): Promise<void> {
    const query = `
      UPDATE documents
      SET processing_status = $1, updated_at = NOW()
      WHERE id = $2
    `;
    
    await getPool().query(query, [status, id]);
  }
}
```

