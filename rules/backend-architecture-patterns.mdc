# Backend Architecture Pattern

This project follows a strict layered architecture pattern to ensure separation of concerns, maintainability, and type safety.

## Implementation Sequence

Always implement features in the following order:

1. **DTOs** - Define data transfer objects first
2. **Models** - Create data models 
3. **Repositories** - Implement database operations (skip if not needed)
4. **Services** - Implement business logic
5. **Controllers** - Create controller methods
6. **Routes** - Define API routes

## Type Safety

- All types must be explicitly defined
- Never use `any` type
- Use interfaces, type aliases, or classes as appropriate
- Use enums for fixed sets of values

## Code Examples

### 1. DTOs (Data Transfer Objects)

```typescript
// src/dtos/document.dto.ts
import {
  IsString,
  IsUUID,
  IsOptional,
  IsInt,
  IsUrl,
  IsEnum,
  IsDate
} from "class-validator";
import { Expose } from "class-transformer";

export class CreateDocumentDto {
  @IsString()
  @Expose()
  title!: string;
  
  @IsUrl()
  @Expose()
  fileUrl!: string;
  
  @IsString()
  @Expose()
  mimeType!: string;
  
  @IsInt()
  @Expose()
  size!: number;
  
  @IsUUID()
  @Expose()
  userId!: string;
}

export class UpdateDocumentDto {
  @IsString()
  @IsOptional()
  @Expose()
  title?: string;
  
  @IsString()
  @IsOptional()
  @Expose()
  description?: string;
}

export class DocumentResponseDto {
  @IsUUID()
  @Expose()
  id!: string;
  
  @IsString()
  @Expose()
  title!: string;
  
  @IsUrl()
  @Expose()
  fileUrl!: string;
  
  @IsString()
  @Expose()
  mimeType!: string;
  
  @IsInt()
  @Expose()
  size!: number;
  
  @IsUUID()
  @Expose()
  userId!: string;
  
  @IsString()
  @IsEnum(ProcessingStatus)
  @Expose()
  processingStatus!: string;
  
  @IsDate()
  @Expose()
  createdAt!: Date;
  
  @IsDate()
  @Expose()
  updatedAt!: Date;
}
```

