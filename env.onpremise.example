# On-Premise Deployment Environment Variables
# Copy this file to .env when deploying to your own infrastructure

# Application Environment
NODE_ENV=production
PORT=3000

# Database Configuration (On-Premise PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=converge_db
DB_USER=converge_user
DB_PASSWORD=your_secure_password_here

# Google Gemini AI Configuration
# Get your API key from: https://ai.google.dev/
GOOGLE_GEMINI_API_KEY=your_gemini_api_key_here

# Optional: GCP Configuration (if using Vertex AI instead of Gemini API)
# GCP_PROJECT_ID=your-gcp-project-id
# VERTEX_AI_LOCATION=us-central1

# CORS Configuration
# Set this to your frontend URL
CORS_ORIGIN=https://your-frontend-domain.com

# Session Configuration
SESSION_SECRET=generate_random_32_character_string_here
SESSION_TIMEOUT_DAYS=30

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=logs/backend.log

# Optional: Rate Limiting
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# Optional: File Upload (if needed)
MAX_UPLOAD_SIZE=10485760

# Health Check
HEALTH_CHECK_ENABLED=true

# Resend Email Configuration
# Get your API key from: https://resend.com/api-keys
RESEND_API_KEY=re_xxxxxxxxxx
SALES_LEAD_RECIPIENT_EMAIL=wayne.chan@tangent.sg
SALES_LEAD_FROM_EMAIL=onboarding@resend.dev
SALES_LEAD_FROM_NAME=GBG Portal

# Notes:
# 1. DB_HOST: Use 'localhost' if database is on same server, or IP/hostname if remote
# 2. DB_PASSWORD: Use a strong password (16+ characters, mix of letters/numbers/symbols)
# 3. GOOGLE_GEMINI_API_KEY: Required for AI chatbot functionality
# 4. CORS_ORIGIN: Must match your frontend URL exactly
# 5. SESSION_SECRET: Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 6. Never commit this file with real credentials to Git!

