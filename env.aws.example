# AWS Deployment Environment Variables
# Copy this file to .env when deploying to AWS (for local testing)

# Application
NODE_ENV=staging
PORT=3000

# AWS RDS Database Configuration
DB_HOST=your-rds-endpoint.rds.amazonaws.com
DB_PORT=5432
DB_NAME=converge_staging_db
DB_USER=postgres
DB_PASSWORD=your-secure-password

# Cloud Provider (for multi-cloud support)
CLOUD_PROVIDER=aws

# Google Cloud (for AI services - still needed for Vertex AI/Gemini)
GCP_PROJECT_ID=your-gcp-project-id
VERTEX_AI_LOCATION=us-central1
GOOGLE_GEMINI_API_KEY=your-gemini-api-key

# AWS Region
AWS_REGION=us-east-1

# Resend Email Configuration
RESEND_API_KEY=re_xxxxxxxxxx
SALES_LEAD_RECIPIENT_EMAIL=wayne.chan@tangent.sg
SALES_LEAD_FROM_EMAIL=onboarding@resend.dev
SALES_LEAD_FROM_NAME=GBG Portal

# Note: When deploying to ECS, most of these are automatically
# set by Terraform in the task definition. This file is mainly
# for local development/testing with AWS RDS.
